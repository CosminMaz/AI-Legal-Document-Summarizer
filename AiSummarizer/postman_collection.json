            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": [],
                  "description": "Select any unsupported file e.g. .zip or .doc"
                },
                {
                  "key": "max_summary_words",
                  "value": "120",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/summarize",
              "host": ["{{base_url}}"],
              "path": ["summarize"]
            },
            "description": "Expects HTTP 415 – unsupported file type. Upload a .zip, .doc, or any other unsupported format."
          }
        },
        {
          "name": "Error – no file field",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "document_title",
                  "value": "Missing file test",
                  "type": "text"
                },
                {
                  "key": "max_summary_words",
