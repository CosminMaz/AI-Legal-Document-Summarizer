@page "/documents"
@layout Layout.MainLayout

<PageTitle>Documents - AI Legal Document Summarizer</PageTitle>

<div class="documents-container">
    <div class="page-header" style="margin-bottom: 2rem;">
        <h1 style="color: var(--primary-color); margin-bottom: 0.5rem;">📄 My Documents</h1>
        <p class="text-muted" style="font-size: 1.1rem;">Manage and upload your legal documents</p>
    </div>

    <div class="upload-section card" style="margin-bottom: 2rem; text-align: center; padding: 3rem;">
        <div style="font-size: 4rem; margin-bottom: 1rem; opacity: 0.5;">📁</div>
        <h3 style="color: var(--primary-color); margin-bottom: 1rem;">Upload Your Documents</h3>
        <p class="text-muted" style="margin-bottom: 2rem;">
            Drag and drop files here or click to browse<br/>
            Supported formats: PDF, DOCX, TXT
        </p>
        <button class="btn btn-primary" style="padding: 1rem 2rem; font-size: 1.1rem;">
            Browse Files
        </button>
    </div>

    <div class="documents-header" style="margin-bottom: 1rem;">
        <h3 style="color: var(--text-primary);">Recent Documents</h3>
    </div>

    <div class="documents-list">
        <div class="card" style="padding: 1.5rem; margin-bottom: 1rem;">
            <div style="display: flex; align-items: center; justify-content: space-between;">
                <div style="display: flex; align-items: center; gap: 1rem;">
                    <div style="font-size: 2.5rem;">📄</div>
                    <div>
                        <h4 style="margin: 0; color: var(--primary-color);">No documents yet</h4>
                        <p class="text-muted" style="margin: 0.25rem 0 0 0; font-size: 0.9rem;">
                            Upload your first document to get started
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .documents-container {
        max-width: 1000px;
        margin: 0 auto;
    }

    .upload-section {
        border: 2px dashed var(--border-color);
        transition: all 0.3s ease;
    }

    .upload-section:hover {
        border-color: var(--primary-color);
        background-color: rgba(30, 64, 175, 0.02);
    }

    .documents-list .card:hover {
        box-shadow: var(--shadow-lg);
        transform: translateY(-2px);
        transition: all 0.2s ease;
    }
</style>

