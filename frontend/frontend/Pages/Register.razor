@page "/register"
@layout Layout.DashboardLayout
@using System.Net.Http
@using System.Net.Http.Json
@using System.Threading.Tasks
@using System.ComponentModel.DataAnnotations
@inject HttpClient Http
@inject NavigationManager NavigationManager

<PageTitle>Register - AI Legal Document Summarizer</PageTitle>

<div class="auth-container">
    <div class="auth-card card">
        <div class="auth-header text-center mb-4">
            <h2 style="color: var(--primary-color); margin-bottom: 0.5rem;">⚖️ Create Account</h2>
            <p class="text-muted">Join us to start summarizing legal documents</p>
        </div>

        <EditForm Model="@_registerModel" OnValidSubmit="@HandleRegister">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <div class="form-group">
                <label for="username">Username</label>
                <InputText id="username" class="form-control" @bind-Value="_registerModel.Username" placeholder="Choose a username" />
            </div>

            <div class="form-group">
                <label for="email">Email Address</label>
                <InputText id="email" class="form-control" @bind-Value="_registerModel.Email" placeholder="your.email@example.com" />
            </div>

            <div class="form-group">
                <label for="password">Password</label>
                <InputText id="password" type="password" class="form-control" @bind-Value="_registerModel.Password" placeholder="At least 6 characters" />
            </div>

            <div class="form-group">
                <label for="confirmPassword">Confirm Password</label>
                <InputText id="confirmPassword" type="password" class="form-control" @bind-Value="_registerModel.ConfirmPassword" placeholder="Re-enter your password" />
            </div>

            <button type="submit" class="btn btn-primary" style="width: 100%; padding: 1rem; font-size: 1.1rem; margin-top: 1rem;">
                Create Account
            </button>
        </EditForm>

        <div class="auth-footer text-center mt-4">
            <p class="text-muted" style="margin: 0;">
                Already have an account? <a href="/login" style="font-weight: 600;">Sign in here</a>
            </p>
        </div>

        @if (!string.IsNullOrEmpty(_message))
        {
            <div class="@(_message.Contains("successful") ? "alert alert-success" : "alert alert-danger") mt-3">@_message</div>
        }
    </div>
</div>

<style>
    .auth-container {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: calc(100vh - 4rem);
        padding: 2rem;
    }

    .auth-card {
        max-width: 450px;
        width: 100%;
    }

    .auth-header h2 {
        font-size: 2rem;
        font-weight: 700;
    }
</style>

@code {
    private RegisterModel _registerModel = new RegisterModel();
    private string? _message;

    private async Task HandleRegister()
    {
        if (_registerModel.Password != _registerModel.ConfirmPassword)
        {
            _message = "Passwords do not match.";
            return;
        }

        try
        {
            var response = await Http.PostAsJsonAsync("/api/v1/auth/register", new { _registerModel.Username, _registerModel.Email, _registerModel.Password });
            if (response.IsSuccessStatusCode)
            {
                _message = "Registration successful! Redirecting to login...";
                await Task.Delay(1500);
                NavigationManager.NavigateTo("/login");
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                _message = $"Registration failed: {errorContent} (Status: {response.StatusCode})";
            }
        }
        catch (Exception ex)
        {
            _message = $"An unexpected error occurred: {ex.Message}";
        }
    }

    public class RegisterModel
    {
        [Required]
        public string? Username { get; set; }

        [Required]
        [EmailAddress]
        public string? Email { get; set; }

        [Required]
        [StringLength(100, ErrorMessage = "The {0} must be at least {2} and at max {1} characters long.", MinimumLength = 6)]
        public string? Password { get; set; }

        [Compare("Password", ErrorMessage = "The password and confirmation password do not match.")]
        public string? ConfirmPassword { get; set; }
    }
}
