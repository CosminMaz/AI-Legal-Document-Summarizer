@page "/dashboard"
@layout Layout.MainLayout

<PageTitle>Dashboard - AI Legal Document Summarizer</PageTitle>

<div class="dashboard-container">
    <div class="hero-section">
        <h1 style="color: var(--primary-color); margin-bottom: 1rem;">⚖️ AI Legal Document Summarizer</h1>
        <p class="lead text-muted" style="font-size: 1.25rem; margin-bottom: 2rem;">
            Transform complex legal documents into clear, concise summaries with the power of AI
        </p>
    </div>

    <div class="features-grid">
        <div class="feature-card card">
            <div class="feature-icon" style="font-size: 3rem; margin-bottom: 1rem;">📄</div>
            <h3 style="color: var(--primary-color); margin-bottom: 0.5rem;">Upload Documents</h3>
            <p class="text-muted">
                Upload your legal documents in various formats including PDF, DOCX, and TXT files for instant analysis.
            </p>
        </div>

        <div class="feature-card card">
            <div class="feature-icon" style="font-size: 3rem; margin-bottom: 1rem;">🤖</div>
            <h3 style="color: var(--primary-color); margin-bottom: 0.5rem;">AI-Powered Analysis</h3>
            <p class="text-muted">
                Our advanced AI models analyze and extract key information from your legal documents automatically.
            </p>
        </div>

        <div class="feature-card card">
            <div class="feature-icon" style="font-size: 3rem; margin-bottom: 1rem;">✨</div>
            <h3 style="color: var(--primary-color); margin-bottom: 0.5rem;">Get Summaries</h3>
            <p class="text-muted">
                Receive clear, concise summaries highlighting the most important clauses and terms in seconds.
            </p>
        </div>
    </div>

    <div class="cta-section card" style="margin-top: 2rem; text-align: center; background: linear-gradient(135deg, #1e40af 0%, #1e3a8a 100%); color: white;">
        <h2 style="color: white; margin-bottom: 1rem;">Ready to Get Started?</h2>
        <p style="font-size: 1.1rem; margin-bottom: 1.5rem; opacity: 0.9;">
            Upload your first document now and experience the power of AI-driven legal analysis.
        </p>
        <button class="btn" style="background-color: white; color: var(--primary-color); font-weight: 600; font-size: 1.1rem;">
            Upload Document
        </button>
    </div>
</div>

<style>
    .dashboard-container {
        max-width: 1200px;
        margin: 0 auto;
    }

    .hero-section {
        text-align: center;
        padding: 2rem 0 3rem;
    }

    .hero-section h1 {
        font-size: 2.5rem;
        font-weight: 800;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
        gap: 2rem;
        margin-bottom: 2rem;
    }

    .feature-card {
        text-align: center;
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .feature-card:hover {
        transform: translateY(-5px);
        box-shadow: var(--shadow-xl);
    }

    .feature-icon {
        display: inline-block;
    }

    .cta-section {
        padding: 3rem 2rem;
    }

    @@media (max-width: 768px) {
        .hero-section h1 {
            font-size: 2rem;
        }

        .features-grid {
            grid-template-columns: 1fr;
        }
    }
</style>
